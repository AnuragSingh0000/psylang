Parsed OK
PROGRAM
  TYPE_DECL (Point)
    VAR_DECL (x)
      VAR_TYPE (float)
    VAR_DECL (y)
      VAR_TYPE (float)
  TYPE_DECL (Rect)
    VAR_DECL (origin)
      VAR_TYPE (Point)
    VAR_DECL (width)
      VAR_TYPE (float)
    VAR_DECL (height)
      VAR_TYPE (float)
  FUN_DECL (isInside)
    FUNCTION
      TYPED_VAR (p)
        VAR_TYPE (Point)
      TYPED_VAR (r)
        VAR_TYPE (Rect)
      VAR_TYPE (bool)
      BLOCK
        VAR_DECL (withinX)
          VAR_TYPE (bool)
          BINARY (&&)
            BINARY (>=)
              MEMBER (.x)
                PRIMARY (p)
              MEMBER (.x)
                MEMBER (.origin)
                  PRIMARY (r)
            BINARY (<=)
              MEMBER (.x)
                PRIMARY (p)
              BINARY (+)
                MEMBER (.x)
                  MEMBER (.origin)
                    PRIMARY (r)
                MEMBER (.width)
                  PRIMARY (r)
        VAR_DECL (withinY)
          VAR_TYPE (bool)
          BINARY (&&)
            BINARY (>=)
              MEMBER (.y)
                PRIMARY (p)
              MEMBER (.y)
                MEMBER (.origin)
                  PRIMARY (r)
            BINARY (<=)
              MEMBER (.y)
                PRIMARY (p)
              BINARY (+)
                MEMBER (.y)
                  MEMBER (.origin)
                    PRIMARY (r)
                MEMBER (.height)
                  PRIMARY (r)
        RETURN
          BINARY (&&)
            PRIMARY (withinX)
            PRIMARY (withinY)
  VAR_DECL (myPoint)
    VAR_TYPE (Point)
  EXPR_STMT
    ASSIGN (=)
      MEMBER (.x)
        PRIMARY (myPoint)
      PRIMARY (5.000000)
  EXPR_STMT
    ASSIGN (=)
      MEMBER (.y)
        PRIMARY (myPoint)
      PRIMARY (10.000000)
  VAR_DECL (myRect)
    VAR_TYPE (Rect)
  EXPR_STMT
    ASSIGN (=)
      MEMBER (.x)
        MEMBER (.origin)
          PRIMARY (myRect)
      PRIMARY (0.000000)
  EXPR_STMT
    ASSIGN (=)
      MEMBER (.y)
        MEMBER (.origin)
          PRIMARY (myRect)
      PRIMARY (0.000000)
  EXPR_STMT
    ASSIGN (=)
      MEMBER (.width)
        PRIMARY (myRect)
      PRIMARY (10.000000)
  EXPR_STMT
    ASSIGN (=)
      MEMBER (.height)
        PRIMARY (myRect)
      PRIMARY (20.000000)
  IF
    CALL
      PRIMARY (isInside)
      PRIMARY (myPoint)
      PRIMARY (myRect)
    ECHO
      PRIMARY ("Collision detected")
    ECHO
      PRIMARY ("No collision")
