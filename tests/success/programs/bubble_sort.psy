fun bubbleSort(arr: dyn, n: int) -> dyn {
    for (var int i = 0; i < n - 1; i++)
        for (var int j = 0; j < n - 1; j++)
            if (arr[j] > arr[j + 1]) {
                var dyn temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }

    ret arr;
}

var list[5] arr = [5, 1, 4, 2, 8];
arr = bubbleSort(arr, 5);

echo arr;