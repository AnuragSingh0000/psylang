Grammar

    0 $accept: program $end

    1 program: decList

    2 decList: decList declaration
    3        | declaration

    4 declaration: typeDecl
    5            | funDecl
    6            | varDecl
    7            | statement

    8 typeDecl: "type" IDENTIFIER "{" inTypeDeclList "}"

    9 funDecl: "fun" IDENTIFIER function

   10 function: "(" parameters ")" "->" var_type block
   11         | "(" ")" "->" var_type block

   12 parameters: parameters "," typedVar
   13           | typedVar

   14 typedVar: IDENTIFIER ":" var_type

   15 var_type: "int"
   16         | "float"
   17         | "string"
   18         | "bool"
   19         | "dyn"
   20         | "list" "[" INT_CONSTANT "]"
   21         | "null"
   22         | IDENTIFIER

   23 inTypeDeclList: inTypeDeclList inTypeDecl
   24               | inTypeDecl

   25 inTypeDecl: varDecl
   26           | typeDecl
   27           | funDecl

   28 varDecl: "var" var_type IDENTIFIER "=" expression ";"
   29        | "var" var_type IDENTIFIER ";"

   30 statement: exprStmt
   31          | forStmt
   32          | ifStmt
   33          | echoStmt
   34          | returnStmt
   35          | whileStmt
   36          | dowhileStmt
   37          | breakStmt
   38          | continueStmt
   39          | block

   40 exprStmt: expression ";"

   41 forStmt: "for" "(" forInit optExpr ";" optExpr ")" statement

   42 forInit: varDecl
   43        | exprStmt
   44        | ";"

   45 optExpr: expression
   46        | ε

   47 ifStmt: "if" "(" expression ")" statement "else" statement
   48       | "if" "(" expression ")" statement

   49 echoStmt: "echo" expression ";"

   50 returnStmt: "ret" expression ";"
   51           | "ret" ";"

   52 whileStmt: "while" "(" expression ")" statement

   53 dowhileStmt: "do" statement "while" "(" expression ")" ";"

   54 breakStmt: "break" ";"

   55 continueStmt: "continue" ";"

   56 block: "{" decList "}"
   57      | "{" "}"

   58 expression: assignment

   59 assignment: call_access "=" assignment
   60           | call_access "+=" assignment
   61           | call_access "-=" assignment
   62           | call_access "*=" assignment
   63           | call_access "/=" assignment
   64           | call_access "%=" assignment
   65           | ternary

   66 ternary: logic_or "?" assignment ":" assignment
   67        | logic_or

   68 logic_or: logic_or "||" logic_and
   69         | logic_and

   70 logic_and: logic_and "&&" bitwise_or
   71          | bitwise_or

   72 bitwise_or: bitwise_or "|" bitwise_xor
   73           | bitwise_xor

   74 bitwise_xor: bitwise_xor "^" bitwise_and
   75            | bitwise_and

   76 bitwise_and: bitwise_and "&" equality
   77            | equality

   78 equality: equality "!=" comparison
   79         | equality "==" comparison
   80         | comparison

   81 comparison: comparison ">" shift
   82           | comparison "<" shift
   83           | comparison ">=" shift
   84           | comparison "<=" shift
   85           | shift

   86 shift: shift "<<" term
   87      | shift ">>" term
   88      | term

   89 term: term "+" factor
   90     | term "-" factor
   91     | factor

   92 factor: factor "/" unary
   93       | factor "*" unary
   94       | factor "%" unary
   95       | unary

   96 unary: "!" unary
   97      | "~" unary
   98      | "-" unary
   99      | "++" unary
  100      | "--" unary
  101      | call_access

  102 call_access: call_access "(" arguments ")"
  103            | call_access "(" ")"
  104            | call_access "." IDENTIFIER
  105            | call_access "[" expression "]"
  106            | call_access "++"
  107            | call_access "--"
  108            | primary

  109 primary: BOOL_CONSTANT
  110        | "null"
  111        | INT_CONSTANT
  112        | FLOAT_CONSTANT
  113        | STRING_CONSTANT
  114        | IDENTIFIER
  115        | anonFunc
  116        | "(" expression ")"
  117        | "[" elements "]"
  118        | "[" "]"

  119 anonFunc: "lambda" function

  120 arguments: arguments "," expression
  121          | expression

  122 elements: elements "," expression
  123         | expression


